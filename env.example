# =============================================================================
# LLM Security Test Harness - Configuration
# Copy this file to .env and fill in your keys
# =============================================================================

# --- LM Studio (local) ---
# Default LM Studio server address. No real API key needed.
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio

# --- Anthropic (Claude) ---
# Used for both test subjects AND Opus-as-Judge evaluation
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- OpenRouter ---
# Provides access to many models via a single API
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Judge Configuration ---
# The model used to evaluate all other models' responses
JUDGE_MODEL=claude-opus-4-20250514
# Set to "anthropic" or "openrouter" depending on where you want to run the judge
JUDGE_BACKEND=anthropic

# --- NVD API (optional, increases rate limit from 5 to 50 req/30s) ---
NVD_API_KEY=

# --- Output ---
RESULTS_DIR=./results
